# ── Extracted entities (named graph) ────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250115T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_TanyaSprintRetro a narr:Sample ;
      dct:title "Tanya's Sprint Retro" ;
      narr:inputLength 213 ;
      dct:description "Sprint retrospective note from Tanya reporting on widget shipment, velocity, and Zephyr integration." .

    # ── Actor ───────────────────────────────────────────────────
    narr:Actor_Tanya_SprintRetro a narr:Actor ;
      skos:prefLabel "Tanya" ;
      skos:note "Sprint team member reporting retrospective results; speaker of the quoted statement about velocity and Zephyr integration." .

    # ── Narratives ──────────────────────────────────────────────
    narr:Narrative_AsyncWidgetShipVelocityRecord a narr:Narrative ;
      narr:theme "Team shipped async decision widget at record velocity" ;
      skos:broader narr:Proof ;
      skos:note "The sprint team delivered the async decision widget and achieved 23 story points — the highest velocity of the quarter — signalling strong execution momentum." ;
      dct:source narr:Sample_TanyaSprintRetro .

    narr:Narrative_ZephyrIntegrationKeyUnlock a narr:Narrative ;
      narr:theme "Zephyr integration was the key unlock enabling sprint success" ;
      skos:broader narr:TechnologiesSocialSystems ;
      skos:note "Tanya attributes the velocity record and widget shipment to the Zephyr integration as the enabling dependency that unlocked the sprint outcome." ;
      dct:source narr:Sample_TanyaSprintRetro .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_Velocity23PointsHighestThisQuarter a narr:Claim ;
      narr:aboutNode narr:Narrative_AsyncWidgetShipVelocityRecord ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      skos:note "Tanya states velocity was 23 points, explicitly described as highest this quarter." ;
      narr:supports narr:Narrative_AsyncWidgetShipVelocityRecord ;
      dct:source narr:Sample_TanyaSprintRetro .

    narr:Claim_ZephyrWasKeyUnlock a narr:Claim ;
      narr:aboutNode narr:Narrative_ZephyrIntegrationKeyUnlock ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      skos:note "Tanya asserts Zephyr integration was the key unlock — a causal attribution from a single speaker without corroborating evidence." ;
      narr:supports narr:Narrative_ZephyrIntegrationKeyUnlock ;
      dct:source narr:Sample_TanyaSprintRetro .

    # ── Observations ────────────────────────────────────────────
    narr:Obs_AsyncWidgetShipped a narr:Observation ;
      skos:broader narr:CaseResults ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya confirms the async decision widget was shipped this sprint." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 86 ;
        oa:end 123
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We shipped the async decision widget." ;
        oa:prefix "Tanya: \"" ;
        oa:suffix " Velocity was 23 points"
      ] .

    narr:Obs_VelocityRecord a narr:Observation ;
      skos:broader narr:NorthStarMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Velocity of 23 points reported as highest this quarter — a quantified performance milestone." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 124 ;
        oa:end 169
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Velocity was 23 points, highest this quarter." ;
        oa:prefix "async decision widget. " ;
        oa:suffix " The Zephyr integration"
      ] .

    narr:Obs_ZephyrUnlock a narr:Observation ;
      skos:broader narr:DependenciesIntegrations ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya attributes the sprint success to the Zephyr integration as the key enabling factor." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 170 ;
        oa:end 212
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "The Zephyr integration was the key unlock." ;
        oa:prefix "highest this quarter. " ;
        oa:suffix "\""
      ] .

    # ── Style Observations ───────────────────────────────────────
    narr:StyleObs_DirectQuoteFirstPerson a narr:StyleObservation ;
      skos:broader narr:FirstPerson ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Speaker uses first-person plural ('We shipped') — direct attribution of team action." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 86 ;
          oa:end 123
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " Velocity was 23 points"
        ]
      ] .

    narr:StyleObs_ShortPunchyCadence a narr:StyleObservation ;
      skos:broader narr:ShortPunchyCadence ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Three short declarative sentences in sequence: shipped widget, velocity stat, Zephyr unlock. Classic punchy retro cadence." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 86 ;
          oa:end 212
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget. Velocity was 23 points, highest this quarter. The Zephyr integration was the key unlock." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix "\""
        ]
      ] .

    narr:StyleObs_ConfidentAssertiveTone a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "No hedging language. Declarative assertions ('was the key unlock', 'highest this quarter') signal confident, authoritative retrospective voice." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 170 ;
          oa:end 212
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "The Zephyr integration was the key unlock." ;
          oa:prefix "highest this quarter. " ;
          oa:suffix "\""
        ]
      ] .

    # ── Style Metrics ────────────────────────────────────────────
    narr:StyleMetrics_TanyaSprintRetro a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:AverageSentenceLength "10"^^xsd:integer ;
      narr:ActiveVoiceRatio "1.0"^^xsd:decimal ;
      narr:JargonDensity "0.15"^^xsd:decimal ;
      skos:note "Three sentences averaging ~10 words each. 100% active voice. Mild jargon: 'async', 'Zephyr', 'velocity points'. Register: direct, confident, team-facing retro voice." .

