# ── Extracted entities (named graph) ────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250130T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_TanyaSprintRetro a narr:Sample ;
      dct:title "Tanya's Sprint Retro" ;
      narr:inputLength 212 ;
      dct:description "Sprint retrospective note from Tanya covering widget delivery, velocity record, and Zephyr integration unlock." .

    # ── Actor ───────────────────────────────────────────────────
    narr:Actor_Tanya_SprintRetro a narr:Actor ;
      skos:prefLabel "Tanya" ;
      skos:note "Sprint team member reporting retrospective outcomes; speaker of the quoted statement." .

    # ── Narrative ───────────────────────────────────────────────
    narr:Narrative_AsyncWidgetDelivery a narr:Narrative ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:theme "Successful sprint delivery driven by a key integration unlock" ;
      skos:broader narr:Proof ;
      skos:note "The team shipped the async decision widget at record quarterly velocity (23 points), attributed to the Zephyr integration as the enabling unlock." .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_VelocityRecord_Q a narr:Claim ;
      narr:aboutNode narr:Narrative_AsyncWidgetDelivery ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_AsyncWidgetDelivery ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Velocity of 23 points was the highest this quarter, as stated by Tanya in the sprint retro." .

    narr:Claim_ZephyrKeyUnlock a narr:Claim ;
      narr:aboutNode narr:Narrative_AsyncWidgetDelivery ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_AsyncWidgetDelivery ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "The Zephyr integration was identified as the key unlock enabling the sprint's delivery success." .

    # ── Observations ────────────────────────────────────────────
    narr:Obs_ShippedWidget a narr:Observation ;
      skos:broader narr:CaseResults ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya confirms the async decision widget was shipped this sprint." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 95 ;
          oa:end 132
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " Velocity was 23 points"
        ]
      ] .

    narr:Obs_VelocityHighest a narr:Observation ;
      skos:broader narr:NorthStarMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Velocity of 23 points recorded as highest this quarter." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 133 ;
          oa:end 178
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "Velocity was 23 points, highest this quarter." ;
          oa:prefix "async decision widget. " ;
          oa:suffix " The Zephyr integration"
        ]
      ] .

    narr:Obs_ZephyrUnlock a narr:Observation ;
      skos:broader narr:CaseLessons ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Zephyr integration named as the key unlock for sprint success." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 179 ;
          oa:end 221
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "The Zephyr integration was the key unlock." ;
          oa:prefix "highest this quarter. " ;
          oa:suffix ""
        ]
      ] .

    # ── Style Observations ───────────────────────────────────────
    narr:StyleObs_FirstPersonPlural a narr:StyleObservation ;
      skos:broader narr:FirstPerson ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "Speaker uses first-person plural ('We shipped') to frame delivery as a team achievement rather than individual." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 95 ;
          oa:end 107
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped" ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " the async decision widget"
        ]
      ] .

    narr:StyleObs_DeclarativeCadence a narr:StyleObservation ;
      skos:broader narr:ShortPunchyCadence ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "Three short declarative sentences in sequence: shipped widget / velocity record / key unlock. Classic short-punchy cadence with no hedging." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 95 ;
          oa:end 221
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget. Velocity was 23 points, highest this quarter." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " The Zephyr integration"
        ]
      ] .

    narr:StyleObs_JargonTech a narr:StyleObservation ;
      skos:broader narr:JargonPolicy ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "Product/engineering jargon used without definition: 'async decision widget', 'Zephyr integration', 'velocity', 'key unlock'. Assumes insider audience." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 107 ;
          oa:end 221
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "async decision widget. Velocity was 23 points, highest this quarter. The Zephyr integration was the key unlock." ;
          oa:prefix "We shipped the " ;
          oa:suffix ""
        ]
      ] .

    # ── Style Metrics ────────────────────────────────────────────
    narr:StyleMetrics_TanyaSprintRetro a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:AverageSentenceLength 14 ;
      narr:ActiveVoiceRatio "1.0"^^xsd:decimal ;
      narr:JargonDensity "0.25"^^xsd:decimal ;
      skos:note "Three sentences, all active voice, short and declarative. High jargon density for an insider audience (async widget, Zephyr, velocity, unlock)." .

