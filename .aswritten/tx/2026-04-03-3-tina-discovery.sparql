      skos:note "Tina summarizes the universal pattern across all five interviewees: decision made in thread, re-questioned weeks later, thread unfindable." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 430 ;
        oa:end 623
      ] ;
