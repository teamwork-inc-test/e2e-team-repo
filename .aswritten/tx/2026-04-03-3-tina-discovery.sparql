  GRAPH narr:Tx_20260315T130000Z {
    narr:Obs_Lead1_NotionFails
      a narr:Observation ;
      skos:broader narr:FrictionFailure ;
      dct:source narr:Sample_CustomerDiscovery_DecisionFatigue_20260315 ;
      skos:note "Lead 1 describes the Notion failure pattern: decision happens in Slack, the dedicated log stays empty. Validates tool fatigue claim." ;
