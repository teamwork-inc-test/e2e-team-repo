        a oa:TextPositionSelector ;
        oa:start 684 ;
        oa:end 800
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We tried Notion for decision logs. Nobody updates it. The decision happens in Slack and the Notion page stays empty." ;
