      dct:source narr:Sample_CustomerDiscovery_DecisionFatigue_20260315 ;
      skos:note "Lead 5 identifies context loss as the deeper failure: finding the decision record is insufficient if the reasoning is absent, causing re-debate anyway." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 1031 ;
        oa:end 1190
      ] ;
      oa:hasSelector [
