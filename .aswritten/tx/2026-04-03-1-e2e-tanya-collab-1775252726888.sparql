      ] .

    narr:StyleObs_CausalAttributionPhrasing a narr:StyleObservation ;
      skos:broader narr:IdiolectPhrasing ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "'The X was the key unlock' is a distinctive causal attribution idiom — frames a single factor as the decisive enabler." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start "164"^^xsd:integer ;
