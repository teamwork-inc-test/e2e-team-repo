# Extracted entities (named graph)
INSERT DATA {
  GRAPH narr:Tx_20250115T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_TanyaSprintRetro a narr:Sample ;
      dct:title "Tanya's Sprint Retro" ;
      narr:inputLength 213 ;
      dct:description "Sprint retrospective note from Tanya covering velocity, shipped features, and integration unlock." .

    # ── Actor ───────────────────────────────────────────────────
    narr:Actor_Tanya_SprintRetro a narr:Actor ;
      skos:prefLabel "Tanya" ;
      skos:note "Sprint team member reporting on retro outcomes; attributed as speaker of the retro statement." .

    # ── Narrative ───────────────────────────────────────────────
    narr:Narrative_VelocityRecordZephyrUnlock a narr:Narrative ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:theme "Record sprint velocity achieved through a key integration unlock" ;
      skos:broader narr:Proof ;
      skos:note "The team shipped the async decision widget and hit 23 points — the highest velocity this quarter — attributing the breakthrough to the Zephyr integration." .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_AsyncWidgetShipped a narr:Claim ;
      narr:aboutNode narr:Narrative_VelocityRecordZephyrUnlock ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_VelocityRecordZephyrUnlock ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya states the async decision widget was shipped this sprint." .

    narr:Claim_VelocityHighestThisQuarter a narr:Claim ;
      narr:aboutNode narr:Narrative_VelocityRecordZephyrUnlock ;
      narr:hasConvictionLevel narr:Conviction_Boulder ;
      narr:supports narr:Narrative_VelocityRecordZephyrUnlock ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Velocity was 23 points, asserted as the highest this quarter." .

    narr:Claim_ZephyrIntegrationKeyUnlock a narr:Claim ;
      narr:aboutNode narr:Narrative_VelocityRecordZephyrUnlock ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      narr:supports narr:Narrative_VelocityRecordZephyrUnlock ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya attributes the velocity record to the Zephyr integration as the key unlock." .

    # ── Observation ─────────────────────────────────────────────
    narr:Observation_TanyaQuote_SprintRetro a narr:Observation ;
      skos:broader narr:Quotes ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Verbatim retro statement from Tanya covering shipped widget, velocity, and Zephyr unlock." ;
      oa:hasSelector [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 79 ;
          oa:end 213
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget. Velocity was 23 points, highest this quarter. The Zephyr integration was the key unlock." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix "\""
        ]
      ] .

    # ── Style Observations ──────────────────────────────────────

    # 1. Direct personal tone — first-person plural "We shipped"
    narr:StyleObs_DirectPersonalTone a narr:StyleObservation ;
      skos:broader narr:ToneDirectPersonal ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "Speaker uses first-person plural to assert team ownership of delivery." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 79 ;
          oa:end 108
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped the async decision widget." ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " Velocity was"
        ]
      ] .

    # 2. Authoritative superlative — "highest this quarter"
    narr:StyleObs_AuthoritativeSuperlative a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "Superlative framing ('highest this quarter') asserts record-setting performance with confidence." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 109 ;
          oa:end 155
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "Velocity was 23 points, highest this quarter." ;
          oa:prefix "async decision widget. " ;
          oa:suffix " The Zephyr"
        ]
      ] .

    # 3. Metaphor — "key unlock" as causal framing
    narr:StyleObs_KeyUnlockMetaphor a narr:StyleObservation ;
      skos:broader narr:Metaphor ;
      dct:source narr:Sample_TanyaSprintRetro ;
      rdf:value true ;
      skos:note "'Key unlock' is a product/engineering metaphor attributing causal agency to the Zephyr integration." ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 156 ;
          oa:end 212
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "The Zephyr integration was the key unlock." ;
          oa:prefix "highest this quarter. " ;
          oa:suffix "\""
        ]
      ] .

    # ── Style Metrics ───────────────────────────────────────────
    narr:StyleMetrics_TanyaSprintRetro a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:AverageSentenceLength 12 ;
      narr:ActiveVoiceRatio "0.95"^^xsd:decimal ;
      narr:JargonDensity "0.15"^^xsd:decimal ;
      skos:note "Three short declarative sentences; near-total active voice; light technical jargon ('async', 'Zephyr integration', 'velocity points')." .

  }
}