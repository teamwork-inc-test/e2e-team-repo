          oa:prefix "Tanya: \"" ;
          oa:suffix " The Zephyr integration"
        ]
      ] .

    narr:StyleObservation_TechJargonTerms a narr:StyleObservation ;
      skos:broader narr:JargonPolicy ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Technical product terms ('async decision widget', 'Zephyr integration') used without definition, assuming audience familiarity — consistent with internal team communication register." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 97 ;
          oa:end 120
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "async decision widget" ;
          oa:prefix "We shipped the " ;
          oa:suffix ". Velocity was"
        ]
      ] .

    # ── Style Metrics ────────────────────────────────────────────
    narr:StyleMetrics_TanyaSprintRetro a narr:StyleMetrics ;
      skos:broader narr:StyleMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:AverageSentenceLength 10 ;
      narr:ActiveVoiceRatio "0.95"^^xsd:decimal ;
      narr:JargonDensity "0.15"^^xsd:decimal ;
      skos:note "Three short declarative sentences averaging ~10 words each. Near-total active voice. Moderate jargon density from product/integration terminology ('async decision widget', 'Zephyr integration', 'velocity'). Register is internal team, confident, unhedged." .

