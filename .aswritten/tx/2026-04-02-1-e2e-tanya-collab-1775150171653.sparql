# ── Extracted entities (named graph) ────────────────────────────
INSERT DATA {
  GRAPH narr:Tx_20250115T120000Z {

    # ── Sample ──────────────────────────────────────────────────
    narr:Sample_TanyaSprintRetro a narr:Sample ;
      dct:title "Tanya's Sprint Retro" ;
      narr:inputLength 213 ;
      dct:description "Sprint retrospective note from Tanya reporting shipped async decision widget, record velocity of 23 points, and Zephyr integration as key unlock." .

    # ── Actor ───────────────────────────────────────────────────
    narr:Actor_Tanya_SprintRetro a narr:Actor ;
      skos:prefLabel "Tanya" ;
      skos:note "Sprint team member reporting retrospective outcomes; attributed speaker of the retro quote." .

    # ── Narratives ──────────────────────────────────────────────
    narr:Narrative_AsyncWidgetVelocityRecord a narr:Narrative ;
      narr:theme "Shipping the async decision widget at record sprint velocity" ;
      skos:broader narr:Proof ;
      skos:note "The team shipped the async decision widget in a sprint that achieved 23 points — the highest velocity this quarter. Framed as a delivery milestone and performance signal." ;
      dct:source narr:Sample_TanyaSprintRetro .

    narr:Narrative_ZephyrIntegrationUnlock a narr:Narrative ;
      narr:theme "Zephyr integration as the enabling unlock for sprint success" ;
      skos:broader narr:TechnologiesSocialSystems ;
      skos:note "The Zephyr integration is identified as the key unlock that enabled the velocity record and widget delivery. Positions a technical integration as a causal lever for team performance." ;
      dct:source narr:Sample_TanyaSprintRetro .

    # ── Claims ──────────────────────────────────────────────────
    narr:Claim_VelocityHighestThisQuarter a narr:Claim ;
      narr:aboutNode narr:Narrative_AsyncWidgetVelocityRecord ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      skos:note "Velocity was 23 points, asserted as highest this quarter by Tanya in sprint retro." ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:supports narr:Narrative_AsyncWidgetVelocityRecord .

    narr:Claim_ZephyrKeyUnlock a narr:Claim ;
      narr:aboutNode narr:Narrative_ZephyrIntegrationUnlock ;
      narr:hasConvictionLevel narr:Conviction_Stake ;
      skos:note "The Zephyr integration was the key unlock — attributed directly to Tanya's retro statement." ;
      dct:source narr:Sample_TanyaSprintRetro ;
      narr:supports narr:Narrative_ZephyrIntegrationUnlock .

    # ── Observations ────────────────────────────────────────────
    narr:Observation_TanyaQuote_ShippedWidget a narr:Observation ;
      skos:broader narr:Outcomes ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Tanya confirms the async decision widget was shipped this sprint." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 85 ;
        oa:end 123
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "We shipped the async decision widget." ;
        oa:prefix "Tanya: \"" ;
        oa:suffix " Velocity was 23"
      ] .

    narr:Observation_TanyaQuote_VelocityRecord a narr:Observation ;
      skos:broader narr:NorthStarMetrics ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Velocity of 23 points reported as highest this quarter — a quantified performance peak." ;
      oa:hasSelector [
