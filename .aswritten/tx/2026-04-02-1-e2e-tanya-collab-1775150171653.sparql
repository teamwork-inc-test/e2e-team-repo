        oa:start 124 ;
        oa:end 172
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "Velocity was 23 points, highest this quarter." ;
        oa:prefix "async decision widget. " ;
        oa:suffix " The Zephyr integration"
      ] .

    narr:Observation_TanyaQuote_ZephyrUnlock a narr:Observation ;
      skos:broader narr:StackOverview ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Zephyr integration named as the key unlock — causal attribution for sprint success." ;
      oa:hasSelector [
        a oa:TextPositionSelector ;
        oa:start 173 ;
        oa:end 212
      ] ;
      oa:hasSelector [
        a oa:TextQuoteSelector ;
        oa:exact "The Zephyr integration was the key unlock." ;
        oa:prefix "highest this quarter. " ;
        oa:suffix "\""
      ] .

    # ── Style Observations ───────────────────────────────────────
    narr:StyleObservation_FirstPersonPlural a narr:StyleObservation ;
      skos:broader narr:FirstPerson ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Speaker uses first-person plural ('We shipped') to attribute delivery to the team collectively, not individually." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 85 ;
          oa:end 96
        ] ;
        oa:hasSelector [
          a oa:TextQuoteSelector ;
          oa:exact "We shipped" ;
          oa:prefix "Tanya: \"" ;
          oa:suffix " the async decision"
        ]
      ] .

    narr:StyleObservation_DirectDeclarativeTone a narr:StyleObservation ;
      skos:broader narr:ToneAuthoritative ;
      dct:source narr:Sample_TanyaSprintRetro ;
      skos:note "Three short declarative sentences in sequence ('We shipped... Velocity was... The Zephyr integration was...') create a confident, authoritative retro cadence with no hedging." ;
      rdf:value true ;
      oa:hasTarget [
        a oa:SpecificResource ;
        oa:hasSource narr:Sample_TanyaSprintRetro ;
        oa:hasSelector [
          a oa:TextPositionSelector ;
          oa:start 85 ;
          oa:end 213
        ] ;
        oa:hasSelector [
